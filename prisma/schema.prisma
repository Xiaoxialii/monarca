generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  VIEWER
}

enum DataSourceType {
  SQL_SERVER
  POSTGRESQL
  SNOWFLAKE
  BIGQUERY
  EXCEL
  CSV
  GOOGLE_ANALYTICS
  STRIPE
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  FAILED
  DISCONNECTED
}

enum MetricLayer {
  PRIMARY
  DRIVER
  DIAGNOSTIC
}

enum MetricMaintainerRole {
  AI
  USER
}

enum MetricStatus {
  AI_READY
  NEEDS_MAPPING
  NEEDS_VALIDATION
}

enum MetricExpressionType {
  AGGREGATE
  RATE
  CALCULATION
}

enum RecommendationStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TicketType {
  DATA_CONNECTION
  REPORT_GENERATION
  BILLING
  ACCOUNT_ACCESS
  OTHER
}

enum TicketPriority {
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SubscriptionPlan {
  TRIAL
  PROFESSIONAL
  ENTERPRISE
  DATABASE_SETUP
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  PENDING
}

enum PlanType {
  ONE_TIME
  MONTHLY
}

enum UserSubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PAYMENT_FAILED
}

enum UserCreditSourceType {
  ONE_TIME_PURCHASE
  MONTHLY_SUBSCRIPTION
}

enum UserCreditStatus {
  ACTIVE
  USED_UP
  EXPIRED
}

enum PaymentOrderType {
  ONE_TIME
  MONTHLY
}

enum PaymentOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum UsageActionType {
  GENERATE_REPORT
  AI_FOLLOW_UP
  DATABASE_CONNECTION
  EXPORT_REPORT
  HUMAN_SERVICE
}

enum WorkspaceMemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

model User {
  id               String            @id @default(cuid())
  clerkUserId      String            @unique
  email            String            @unique
  name             String
  avatarUrl        String?           @map("avatar_url")
  locale           String            @default("en")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      WorkspaceMember[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  maintainedMetrics MetricDefinition[] @relation("MetricMaintainer")
  assignedTickets  SupportTicket[]    @relation("TicketAssignee")
  submittedTickets SupportTicket[]   @relation("TicketSubmitter")
  userSubscriptions UserSubscription[]
  userCredits       UserCredit[]
  paymentOrders     PaymentOrder[]
  usageLogs         UsageLog[]
}

model Workspace {
  id                String               @id @default(cuid())
  slug              String               @unique
  name              String
  ownerId           String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  owner             User                 @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members           WorkspaceMember[]
  dataSources       DataSourceConnection[]
  schemaSnapshots   SchemaSnapshot[]
  metrics           MetricDefinition[]
  briefings         DailyBriefing[]
  supportTickets    SupportTicket[]
  subscriptions     WorkspaceSubscription[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String?
  invitedEmail String?
  role        WorkspaceRole @default(VIEWER)
  status      WorkspaceMemberStatus @default(ACTIVE)
  invitedBy   String?
  clerkInvitationId String? @map("clerk_invitation_id")
  joinedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@unique([workspaceId, invitedEmail])
}

model DataSourceConnection {
  id              String           @id @default(cuid())
  workspaceId     String
  type            DataSourceType
  name            String
  provider        String
  isActive        Boolean          @default(true)
  status          ConnectionStatus @default(PENDING)
  connectionMode  String?
  authMethod      String?
  config          Json?
  schemas         Json?
  lastErrorMessage String?
  connectedAt     DateTime?
  lastSyncAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  schemaSnapshots SchemaSnapshot[]

  @@index([workspaceId, status])
}

model SchemaSnapshot {
  id            String                @id @default(cuid())
  workspaceId   String
  dataSourceId  String?
  version       Int
  status        ConnectionStatus      @default(PENDING)
  schemaJson    Json
  qualityReport Json?
  createdAt     DateTime              @default(now())
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataSource    DataSourceConnection? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, version])
}

model MetricDefinition {
  id            String       @id @default(cuid())
  workspaceId   String
  layer         MetricLayer
  category      String
  name          String
  definition    String
  formula       String
  expressionType MetricExpressionType @default(CALCULATION)
  unit          String?
  window        String?
  sourceMetricIds Json?
  mappingJson   Json?
  lineageJson   Json?
  isActive      Boolean      @default(true)
  maintainerRole MetricMaintainerRole
  maintainerUserId String?
  status        MetricStatus @default(NEEDS_MAPPING)
  tagsJson      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  maintainedByUser User?        @relation("MetricMaintainer", fields: [maintainerUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, layer])
  @@unique([workspaceId, name])
}

model DailyBriefing {
  id            String    @id @default(cuid())
  workspaceId   String
  briefingDate  DateTime
  title         String
  summary       String
  confidence    Int?
  payloadJson   Json?
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  insights      Insight[]

  @@unique([workspaceId, briefingDate])
  @@index([workspaceId, briefingDate])
}

model Insight {
  id                 String                 @id @default(cuid())
  briefingId         String
  title              String
  description        String
  anomalyType        String?
  anomalyTypeNormalized String?
  impactScore        Float?
  confidence         Int?
  dataQualityScore   Int?
  sampleSize         Int?
  relatedMetricIds   Json?
  explanationJson    Json?
  evidenceJson       Json?
  createdAt          DateTime               @default(now())
  briefing           DailyBriefing          @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  recommendations    ActionRecommendation[]
}

model ActionRecommendation {
  id               String   @id @default(cuid())
  insightId        String
  title            String
  ownerTeam        String?
  targetOwner      String?
  executionPriority String?
  impactScore      Float?
  estimatedOutcome String?
  workflowAction   String?
  status           RecommendationStatus @default(PLANNED)
  dueDate          DateTime?
  actualOutcome    String?
  createdAt        DateTime @default(now())
  insight          Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
}

model WorkspaceSubscription {
  id          String             @id @default(cuid())
  workspaceId String
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(PENDING)
  amount      Int
  currency    String             @default("CNY")
  interval    String?
  startedAt   DateTime?
  endedAt     DateTime?
  startPeriod DateTime?
  endPeriod   DateTime?
  trialEndsAt DateTime?
  cancelAt    DateTime?
  planVersion String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model Plan {
  id                      String        @id @default(cuid())
  code                    String        @unique
  name                    String
  type                    PlanType
  price                   Decimal       @db.Decimal(10, 2)
  currency                String        @default("USD")
  description             String
  reportQuota             Int           @default(0)
  aiTokenQuota            Int           @default(0)
  databaseConnectionQuota Int           @default(0)
  includesHumanService    Boolean       @default(false)
  validDays               Int?
  isActive                Boolean       @default(true)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  subscriptions           UserSubscription[]
  credits                 UserCredit[]
  orders                  PaymentOrder[]

  @@index([type, isActive])
}

model UserSubscription {
  id                     String                 @id @default(cuid())
  userId                 String
  planId                 String
  status                 UserSubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean                @default(false)
  paymentProvider        String?
  providerSubscriptionId String?                 @unique
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   Plan                   @relation(fields: [planId], references: [id], onDelete: Restrict)
  credits                UserCredit[]

  @@index([userId, status])
  @@index([planId, status])
}

model UserCredit {
  id                String               @id @default(cuid())
  userId            String
  planId            String
  subscriptionId    String?
  paymentOrderId    String?              @unique
  sourceType        UserCreditSourceType
  reportCreditsTotal Int                 @default(0)
  reportCreditsUsed  Int                 @default(0)
  aiTokenTotal      Int                  @default(0)
  aiTokenUsed       Int                  @default(0)
  validFrom         DateTime             @default(now())
  validUntil        DateTime?
  status            UserCreditStatus     @default(ACTIVE)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan                 @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription      UserSubscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentOrder      PaymentOrder?        @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  usageLogs         UsageLog[]

  @@index([userId, status, validUntil])
  @@index([planId, sourceType])
}

model PaymentOrder {
  id                String             @id @default(cuid())
  userId            String
  planId            String
  orderType         PaymentOrderType
  amount            Decimal            @db.Decimal(10, 2)
  currency          String             @default("USD")
  status            PaymentOrderStatus @default(PENDING)
  paymentProvider   String?
  providerPaymentId String?            @unique
  providerSessionId String?            @unique
  createdAt         DateTime           @default(now())
  paidAt            DateTime?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  credit            UserCredit?

  @@index([userId, status])
  @@index([planId, orderType])
}

model UsageLog {
  id          String          @id @default(cuid())
  userId      String
  actionType  UsageActionType
  creditId    String?
  usageAmount Int             @default(1)
  metadata    Json?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  credit      UserCredit?     @relation(fields: [creditId], references: [id], onDelete: SetNull)

  @@index([userId, actionType, createdAt])
  @@index([creditId, createdAt])
}

model SupportTicket {
  id             String         @id @default(cuid())
  workspaceId    String?
  submitterId    String?
  assigneeId     String?
  type           TicketType
  priority       TicketPriority @default(NORMAL)
  status         TicketStatus   @default(OPEN)
  subject        String
  description    String
  contextJson    Json?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  workspace      Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  submitter      User?          @relation("TicketSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  assignee       User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([submitterId, createdAt])
  @@index([assigneeId, status])
}
